CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_KERNEL_PARTSIZE=60
CONFIG_TARGET_ROOTFS_PARTSIZE=600

# CONFIG_PACKAGE_igmpproxy is not set
CONFIG_PACKAGE_luci-app-omcproxy=y
CONFIG_TARGET_ROOTFS_TARGZ=y
# CONFIG_VMDK_IMAGES is not set
CONFIG_PACKAGE_ddns-scripts_cloudflare.com-v4=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_luci-app-diskman=y



# 主题
# CONFIG_PACKAGE_luci-theme-Light is not set
CONFIG_PACKAGE_luci-theme-argon=y
# CONFIG_PACKAGE_luci-theme-atmaterial-ColorIcon is not set
CONFIG_PACKAGE_luci-app-argon-config=y

CONFIG_PACKAGE_luci-app-ddns=y
# CONFIG_DEFAULT_luci-app-arpbind is not set
# CONFIG_PACKAGE_luci-app-autoreboot is not set
# CONFIG_PACKAGE_luci-app-nlbwmon is not set
# CONFIG_PACKAGE_luci-app-samba4 is not set
# CONFIG_PACKAGE_luci-app-samba is not set
# CONFIG_PACKAGE_luci-app-vlmcsd is not set
# CONFIG_PACKAGE_luci-app-wol is not set

# ssr-plus
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Hysteria is not set

CONFIG_PACKAGE_luci-app-passwall=y
# CONFIG_PACKAGE_luci-app-passwall2 is not set
# CONFIG_PACKAGE_luci-app-docker is not set
# CONFIG_PACKAGE_luci-app-dockerman is not set

CONFIG_PACKAGE_luci-app-udpxy=y
# CONFIG_PACKAGE_luci-app-mwan3 is not set
# CONFIG_PACKAGE_luci-app-mwan3helper is not set
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-app-nikki=y

# ==================================================
# OpenWrt 24.10 L2TP + IPsec/IKEv2 最终整合配置
# 纯IPv4 + swanctl + fw4适配 + 无冲突 + L2TP全功能
# ==================================================

# ---------- L2TP 核心组件 ----------
CONFIG_PACKAGE_xl2tpd=y
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-chap=y
CONFIG_PACKAGE_ppp-mod-pppol2tp=y
CONFIG_PACKAGE_luci-proto-ppp=y
CONFIG_PACKAGE_kmod-ppp=y
CONFIG_PACKAGE_kmod-pppol2tp=y
CONFIG_PACKAGE_kmod-pppox=y

# ---------- 基础内核依赖 ----------
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-ipsec=y
CONFIG_PACKAGE_kmod-ipsec4=y
CONFIG_PACKAGE_kmod-crypto-aes=y
CONFIG_PACKAGE_kmod-crypto-sha1=y
CONFIG_PACKAGE_kmod-crypto-sha256=y
CONFIG_PACKAGE_kmod-crypto-hmac=y

# ---------- strongSwan 核心 ----------
CONFIG_PACKAGE_strongswan=y
CONFIG_PACKAGE_strongswan-charon=y
CONFIG_PACKAGE_strongswan-ipsec=y
CONFIG_PACKAGE_strongswan-swanctl=y
CONFIG_PACKAGE_strongswan-pki=y
# CONFIG_PACKAGE_strongswan-mod-stroke is not set

# ---------- swanctl 核心依赖 ----------
CONFIG_PACKAGE_strongswan-mod-vici=y
CONFIG_PACKAGE_strongswan-mod-kernel-netlink=y
CONFIG_PACKAGE_strongswan-mod-updown=y

# ---------- 基础必需模块 ----------
CONFIG_PACKAGE_strongswan-mod-socket-default=y
CONFIG_PACKAGE_strongswan-mod-nonce=y
CONFIG_PACKAGE_strongswan-mod-random=y
CONFIG_PACKAGE_strongswan-mod-fips-prf=y

# ---------- 加密算法模块 ----------
CONFIG_PACKAGE_strongswan-mod-aes=y
CONFIG_PACKAGE_strongswan-mod-sha1=y
CONFIG_PACKAGE_strongswan-mod-sha2=y
CONFIG_PACKAGE_strongswan-mod-md5=y
CONFIG_PACKAGE_strongswan-mod-hmac=y
CONFIG_PACKAGE_strongswan-mod-xcbc=y
CONFIG_PACKAGE_strongswan-mod-gcm=y
CONFIG_PACKAGE_strongswan-mod-gmp=y
CONFIG_PACKAGE_strongswan-mod-mgf1=y
CONFIG_PACKAGE_strongswan-mod-kdf=y
CONFIG_PACKAGE_strongswan-mod-pbkdf2=y

# ---------- 证书处理模块 ----------
CONFIG_PACKAGE_strongswan-mod-x509=y
CONFIG_PACKAGE_strongswan-mod-pem=y
CONFIG_PACKAGE_strongswan-mod-pkcs1=y
CONFIG_PACKAGE_strongswan-mod-pkcs7=y
CONFIG_PACKAGE_strongswan-mod-pkcs8=y
CONFIG_PACKAGE_strongswan-mod-pkcs12=y
CONFIG_PACKAGE_strongswan-mod-revocation=y
CONFIG_PACKAGE_strongswan-mod-constraints=y

# ---------- EAP 认证模块 ----------
CONFIG_PACKAGE_strongswan-mod-eap-identity=y
CONFIG_PACKAGE_strongswan-mod-eap-md5=y
CONFIG_PACKAGE_strongswan-mod-eap-mschapv2=y
CONFIG_PACKAGE_strongswan-mod-eap-tls=y
CONFIG_PACKAGE_strongswan-mod-eap-ttls=y

# ---------- 辅助模块 ----------
CONFIG_PACKAGE_strongswan-mod-attr=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_luci-app-strongswan-swanctl=y
CONFIG_PACKAGE_luci-i18n-strongswan-swanctl-zh-cn=y

# ---------- fw4 防火墙核心 ----------
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_firewall4-nftables=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-masq=y
CONFIG_PACKAGE_iptables-mod-nat-extra=y

# ---------- 完全禁用的模块 ----------
# IPv6相关
CONFIG_PACKAGE_kmod-ipsec6 is not set
CONFIG_PACKAGE_strongswan-mod-ipv6 is not set
CONFIG_PACKAGE_kmod-nft-ipv6 is not set
CONFIG_PACKAGE_nftables-json-ipv6 is not set

# 冲突模块
CONFIG_PACKAGE_strongswan-mod-kernel-libipsec is not set
CONFIG_PACKAGE_strongswan-mod-connmark is not set
CONFIG_PACKAGE_strongswan-mod-dhcp is not set
CONFIG_PACKAGE_strongswan-mod-farp is not set

# 冗余模块
CONFIG_PACKAGE_strongswan-mod-attr-sql is not set
CONFIG_PACKAGE_strongswan-mod-curl is not set
CONFIG_PACKAGE_strongswan-mod-ldap is not set
CONFIG_PACKAGE_strongswan-mod-mysql is not set
CONFIG_PACKAGE_strongswan-mod-sql is not set
CONFIG_PACKAGE_strongswan-mod-sqlite is not set
CONFIG_PACKAGE_strongswan-mod-uci is not set

# 旧版iptables
CONFIG_PACKAGE_kmod-ipt-nat is not set
