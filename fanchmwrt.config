# fanchmwrt-24.10.4 编译配置文件
# 适配openwrt-24.10分支，x86_64架构，集成Docker、IPsec/L2TP、磁盘分区工具

# 目标架构及分区配置
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_KERNEL_PARTSIZE=60
CONFIG_TARGET_ROOTFS_PARTSIZE=600
CONFIG_TARGET_ROOTFS_TARGZ=y
# 禁用VMDK镜像编译
# CONFIG_VMDK_IMAGES is not set
# 禁用igmpproxy组件
# CONFIG_PACKAGE_igmpproxy is not set

# DDNS组件配置
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y
CONFIG_PACKAGE_ddns-scripts_cloudflare.com-v4=y
CONFIG_PACKAGE_luci-app-ddns=y

# 主题组件配置
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

# 网络插件配置
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-udpxy=y
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-app-nikki=y

# Docker及Web管理组件配置
CONFIG_PACKAGE_docker=y
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_luci-app-docker=y
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_containerd=y
CONFIG_PACKAGE_runc=y
CONFIG_PACKAGE_cgroupfs-mount=y
CONFIG_PACKAGE_kmod-dm=y
CONFIG_PACKAGE_kmod-docker=y
CONFIG_PACKAGE_kmod-ipt-extra=y
CONFIG_PACKAGE_tini=y
CONFIG_PACKAGE_kmod-fs-overlayfs=y
CONFIG_PACKAGE_kmod-cgroup=y
CONFIG_PACKAGE_kmod-cgroup-blkio=y
CONFIG_PACKAGE_kmod-cgroup-cpuset=y
CONFIG_PACKAGE_kmod-cgroup-memory=y

# IPsec/L2TP/IKEv2组件配置，适配docker-ipsec-vpn-server
CONFIG_PACKAGE_libreswan=y
CONFIG_PACKAGE_xl2tpd=y
CONFIG_PACKAGE_strongswan=y
CONFIG_PACKAGE_strongswan-mod-ikev1=y
CONFIG_PACKAGE_strongswan-mod-ikev2=y
CONFIG_PACKAGE_strongswan-mod-kernel-libipsec=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_iptables-mod-ipsec=y
CONFIG_PACKAGE_kmod-ipsec=y
CONFIG_PACKAGE_kmod-ipsec4=y
CONFIG_PACKAGE_kmod-xfrm-interface=y
# IPsec加密驱动组件
CONFIG_PACKAGE_kmod-crypto-aes=y
CONFIG_PACKAGE_kmod-crypto-sha256=y
CONFIG_PACKAGE_kmod-crypto-hmac=y

# 磁盘分区及格式化工具配置
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_blockd=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_parted=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_mount-utils=y
CONFIG_PACKAGE_ntfs-3g=y
# 文件系统驱动组件
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y

# 内核依赖组件，保障Docker及IPsec运行
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-bridge=y
CONFIG_PACKAGE_kmod-ovl=y
CONFIG_PACKAGE_kmod-veth=y
CONFIG_PACKAGE_kmod-macvlan=y
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_DEFAULT_ppp=y
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppol2tp=y

# 编译环境优化配置
CONFIG_DEVEL=y
CONFIG_TOOLCHAINOPTS=y

# 强制启用 cgroup 所有子系统
CONFIG_KERNEL_CGROUP=y
CONFIG_KERNEL_CGROUP_DEVICE=y
CONFIG_KERNEL_CGROUP_FREEZER=y
CONFIG_KERNEL_CGROUP_SCHED=y
CONFIG_KERNEL_CGROUP_CPUACCT=y
CONFIG_KERNEL_CGROUP_MEMCG=y
CONFIG_KERNEL_CGROUP_NET_PRIO=y
CONFIG_KERNEL_CGROUP_PERF=y
CONFIG_KERNEL_CGROUP_BPF=y

# 启用 cgroup 工具链
CONFIG_PACKAGE_libcgroup=y
CONFIG_PACKAGE_libcgroup-tools=y
